<?xml version="1.0" encoding="utf-8" ?>
<configuration>
  <configSections>
    <section name="log4net"
             type="log4net.Config.Log4NetConfigurationSectionHandler, log4net"/>
  </configSections>
    <startup> 
        <supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.7.2" />
    </startup>
  <appSettings>
    <add key="MesUrl" value="http://192.168.0.0/api/aoi" />
    <add key="DemoMode" value="true"/>
  </appSettings>
  <connectionStrings>
    <add name="DbConn"
         connectionString="server=127.0.0.1;database=AAA;uid=groupadmin;password=0000;Connect Timeout=3"
         providerName="System.Data.SqlClient" />
    <add name="DbConn_test"
         connectionString="server=128.1.0.1;database=AAA;uid=groupadmin;password=0000;Connect Timeout=3"
         providerName="System.Data.SqlClient" />
  </connectionStrings>

  <log4net>
    <appender name="RollingFile" type="log4net.Appender.RollingFileAppender">
      <file value="logs/" />
      <appendToFile value="true" />
      <rollingStyle value="Date" />
      <datePattern value="yyyyMMdd'.log'" />
      <staticLogFileName value="false" />
      <layout type="log4net.Layout.PatternLayout">
        <conversionPattern value="%date %-5level %message%newline" />
      </layout>
    </appender>

    <root>
      <level value="ALL" />
      <appender-ref ref="RollingFile" />
    </root>
  </log4net>
</configuration>